PORT=3001

DB_HOST=localhost
DB_PORT=3306
DB_USER=eduverify
DB_PASS=eduverify
DB_NAME=eduverify

JWT_SECRET=change_this_to_a_random_secret_at_least_32_chars

# Google OAuth Client ID (same value used in the frontend GSI script)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Email config for password reset (example: Gmail SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=EduVerify <noreply@eduverify.com>

# Frontend URL (used in password reset email link)
FRONTEND_URL=http://localhost:5173

# Tutor IA (Google Gemini) — opcional; sin key el endpoint responde 503
GEMINI_API_KEY=
AI_MODEL=gemini-2.5-flash
