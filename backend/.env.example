PORT=3001

DB_HOST=localhost
DB_PORT=3306
DB_USER=eduverify
DB_PASS=eduverify
DB_NAME=eduverify

JWT_SECRET=change_this_to_a_random_secret_at_least_32_chars

# Google OAuth Client ID (same value used in the frontend GSI script)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Email — Resend (https://resend.com, gratis 100 emails/día)
RESEND_API_KEY=re_xxxxxxxxxxxx
# Para pruebas sin dominio propio: EMAIL_FROM=EduVerify <onboarding@resend.dev>
# Para producción: verificar tu dominio en resend.com y usar tu dirección
EMAIL_FROM=EduVerify <onboarding@resend.dev>

# Frontend URL (used in password reset email link)
FRONTEND_URL=http://localhost:5173

# Tutor IA (Google Gemini) — opcional; sin key el endpoint responde 503
GEMINI_API_KEY=
AI_MODEL=gemini-2.5-flash

# MinIO (S3 compatible storage) — opcional; sin key el endpoint responde 403
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=eduverify-media
